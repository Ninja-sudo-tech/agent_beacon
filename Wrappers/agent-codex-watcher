#!/usr/bin/env python3
"""
Agent Beacon — Codex CLI session transcript watcher
Complements ~/.codex/hooks.json (UserPromptSubmit / PermissionRequest / Stop)
by catching the same gap found in Claude Code: there is no hook event for
"Codex resumed producing output" after a user denies an exec/patch approval
request. PreToolUse/PostToolUse only fire around an actual tool execution —
denial means the tool never runs, so PostToolUse never fires either. The
light would stay red until Stop, even while Codex keeps working.

Fix: every Codex CLI session is written in real time to
  ~/.codex/sessions/<year>/<month>/<day>/rollout-<timestamp>-<id>.jsonl
Each entry has a "type" field; a `response_item` entry with
payload.role == "assistant" is direct proof Codex is actively producing
output, regardless of why hooks went quiet. We tail the most recently
modified rollout file across all dates and flip the light back to running
whenever a new assistant entry appears.
"""

from __future__ import annotations

import os
import sys
import time
import glob
import json
import subprocess

BEACON       = os.path.expanduser("~/.local/bin/agent-beacon")
SESSIONS_DIR = os.path.expanduser("~/.codex/sessions")
RESCAN_EVERY = 1.0


def set_status(state: str, msg: str):
    try:
        subprocess.run(
            [BEACON, "set", "codex", state, msg],
            capture_output=True, timeout=3
        )
    except Exception:
        pass


def find_active_transcript():
    files = glob.glob(os.path.join(SESSIONS_DIR, "**", "*.jsonl"), recursive=True)
    if not files:
        return None
    return max(files, key=os.path.getmtime)


class CodexWatcher:
    def __init__(self):
        self._current_path = None
        self._fd = None
        self._last_rescan = 0.0

    def _open(self, path):
        if self._fd:
            try:
                self._fd.close()
            except Exception:
                pass
        try:
            self._fd = open(path, "r", errors="replace")
            self._fd.seek(0, 2)
            self._current_path = path
        except OSError:
            self._fd = None

    def _handle_line(self, line: str):
        line = line.strip()
        if not line:
            return
        try:
            d = json.loads(line)
        except (json.JSONDecodeError, ValueError):
            return

        # Any new assistant output proves Codex is actively working —
        # covers the post-denial gap that hooks miss (PostToolUse only
        # fires on actual tool execution, which denial prevents).
        if d.get("type") == "response_item":
            payload = d.get("payload", {})
            if payload.get("role") == "assistant":
                set_status("running", "处理中")

    def run(self):
        path = find_active_transcript()
        while not path:
            print("[agent-codex-watcher] Waiting for a Codex session...", flush=True)
            time.sleep(3)
            path = find_active_transcript()

        self._open(path)
        print(f"[agent-codex-watcher] Watching: {path}", flush=True)

        while True:
            now = time.time()
            if now - self._last_rescan > RESCAN_EVERY:
                self._last_rescan = now
                latest = find_active_transcript()
                if latest and latest != self._current_path:
                    print(f"[agent-codex-watcher] Switched to: {latest}", flush=True)
                    self._open(latest)

            if self._fd:
                for line in self._fd:
                    self._handle_line(line)

            time.sleep(0.1)


if __name__ == "__main__":
    try:
        CodexWatcher().run()
    except KeyboardInterrupt:
        sys.exit(0)
