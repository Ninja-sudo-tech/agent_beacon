#!/usr/bin/env python3
"""
Agent Beacon — Claude Code transcript watcher
Complements the settings.json hooks (UserPromptSubmit / PreToolUse /
PostToolUse / Stop) by catching a gap those hooks cannot see: when the
user denies a permission request (or denies + types custom feedback),
Claude Code has NO hook event for "assistant resumed generating". (Note:
"PermissionRequest" is a documented-sounding hook name but was confirmed
empirically to never actually fire — 0 occurrences across 500+ real tool
calls in session history — so it is not part of this picture; see
agent-beacon-claude-pretooluse for the heuristic that replaces it.)

Fix: Claude Code writes every session turn in real time to
  ~/.claude/projects/<project-slug>/<session-id>.jsonl
Each new "assistant" entry in that transcript is direct proof Claude is
actively working — regardless of why hooks went quiet. We tail the most
recently modified transcript file across all projects and flip the light
back to running whenever a new assistant entry appears.

This does not replace the hooks (which remain faster for the common case);
it's a safety net for the post-denial gap.

Race condition guard: the final "assistant" transcript entry of a turn is
written right before Claude Code fires the Stop hook (→ done). Since this
watcher polls the file on its own schedule, it can read that last entry
AFTER Stop has already set done — overwriting it back to running with
nothing left to correct it (stuck yellow forever, until the next prompt).
Fix: before writing running, check the current status file directly; if
it's already "done" and was set within the last GRACE_SECONDS, skip the
write and let Stop's result stand.
"""

from __future__ import annotations

import os
import sys
import time
import glob
import json
import subprocess
from datetime import datetime, timezone

BEACON       = os.path.expanduser("~/.local/bin/agent-beacon")
STATUS_FILE  = os.path.expanduser("~/.agent-beacon/status/claude.json")
PROJECTS_DIR = os.path.expanduser("~/.claude/projects")
PENDING_DIR  = os.path.expanduser("~/.agent-beacon/claude-pending")
RESCAN_EVERY = 1.0    # seconds between checks for a more-recently-active transcript
GRACE_SECONDS = 1.5   # don't override a "done" set more recently than this


def clear_pending_markers():
    """Remove PreToolUse's pending markers. Called when we detect Claude has
    clearly resumed (pure-text output) — this cancels its 4s timeout fallback,
    which would otherwise fire 'waiting' later for a tool that was denied
    (PostToolUse never runs on denial, so its marker is never cleared there)."""
    try:
        for f in glob.glob(os.path.join(PENDING_DIR, "*")):
            os.remove(f)
    except Exception:
        pass


def set_status(state: str, msg: str):
    try:
        subprocess.run(
            [BEACON, "set", "claude", state, msg],
            capture_output=True, timeout=3
        )
    except Exception:
        pass


def recently_done() -> bool:
    """True if the status file currently says done and was updated within
    the last GRACE_SECONDS — used to avoid racing Stop's result."""
    try:
        with open(STATUS_FILE) as f:
            d = json.load(f)
        if d.get("state") != "done":
            return False
        ts = datetime.strptime(d.get("updatedAt", ""), "%Y-%m-%dT%H:%M:%SZ")
        ts = ts.replace(tzinfo=timezone.utc)
        age = (datetime.now(timezone.utc) - ts).total_seconds()
        return age < GRACE_SECONDS
    except Exception:
        return False


def find_active_transcript() -> str | None:
    """Most recently modified session transcript across all projects —
    almost certainly the session the user is currently interacting with."""
    files = glob.glob(os.path.join(PROJECTS_DIR, "*", "*.jsonl"))
    if not files:
        return None
    return max(files, key=os.path.getmtime)


class ClaudeWatcher:
    def __init__(self):
        self._current_path = None
        self._fd = None
        self._last_rescan = 0.0

    def _open(self, path: str):
        if self._fd:
            try:
                self._fd.close()
            except Exception:
                pass
        try:
            self._fd = open(path, "r", errors="replace")
            self._fd.seek(0, 2)   # start at end — only react to new entries
            self._current_path = path
        except OSError:
            self._fd = None

    def _handle_line(self, line: str):
        line = line.strip()
        if not line:
            return
        try:
            d = json.loads(line)
        except (json.JSONDecodeError, ValueError):
            return
        if d.get("type") == "assistant":
            content = d.get("message", {}).get("content", [])
            if isinstance(content, list) and any(
                isinstance(c, dict) and c.get("type") == "tool_use" for c in content
            ):
                # This entry is what triggers PreToolUse/PermissionRequest —
                # those synchronous hooks own this transition (waiting/running).
                # Setting running here would race PermissionRequest and can
                # overwrite waiting (red) back to running (yellow) before the
                # user even sees the permission dialog.
                return
            if recently_done():
                return   # Stop already fired correctly; don't race it
            # Pure-text assistant output proves Claude is actively working —
            # covers the post-denial / post-custom-feedback gap that hooks miss.
            clear_pending_markers()  # cancel any PreToolUse timeout fallback
            set_status("running", "处理中")

    def run(self):
        path = find_active_transcript()
        while not path:
            print(f"[agent-claude-watcher] Waiting for a Claude Code session...", flush=True)
            time.sleep(3)
            path = find_active_transcript()

        self._open(path)
        print(f"[agent-claude-watcher] Watching: {path}", flush=True)

        while True:
            now = time.time()
            if now - self._last_rescan > RESCAN_EVERY:
                self._last_rescan = now
                latest = find_active_transcript()
                if latest and latest != self._current_path:
                    print(f"[agent-claude-watcher] Switched to: {latest}", flush=True)
                    self._open(latest)

            if self._fd:
                for line in self._fd:
                    self._handle_line(line)

            time.sleep(0.1)


if __name__ == "__main__":
    try:
        ClaudeWatcher().run()
    except KeyboardInterrupt:
        sys.exit(0)
